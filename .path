export GOROOT=/usr/local/opt/go/libexec
export GOPATH=$HOME/ch/workspace/go
export PATH=$PATH:$GOROOT/bin:$GOPATH/bin

# The next line updates PATH for the Google Cloud SDK.
if [ -f '/Users/cengizhan/google-cloud-sdk/path.bash.inc' ]; then source '/Users/cengizhan/google-cloud-sdk/path.bash.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/Users/cengizhan/google-cloud-sdk/completion.bash.inc' ]; then source '/Users/cengizhan/google-cloud-sdk/completion.bash.inc'; fi